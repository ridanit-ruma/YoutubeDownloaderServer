# ──────────────────────────────────────────────────────────────────────────────
# Application configuration — copy to `.env` and adjust for your environment.
# All variables have sensible defaults so the server starts without this file.
# ──────────────────────────────────────────────────────────────────────────────

# TCP port the server listens on.
# Default: 3000
PORT=3000

# Network interface to bind.
# Use 0.0.0.0 inside Docker / production containers.
# Default: 127.0.0.1
HOST=127.0.0.1

# Log level / filter directive (tracing-subscriber EnvFilter syntax).
# Examples:
#   info
#   debug
#   info,tower_http=debug
# Default: info
LOG_LEVEL=info

# Per-request timeout in seconds. Requests that exceed this are aborted.
# Default: 30
REQUEST_TIMEOUT_SECS=30

# ── Database ───────────────────────────────────────────────────────────────────

# PostgreSQL connection URL. Required.
DATABASE_URL=postgres://user:password@localhost:5432/youtube_downloader

# ── JWT Authentication ─────────────────────────────────────────────────────────

# Secret key used to sign JWTs. Use a long random string in production. Required.
JWT_SECRET=change-me-to-a-long-random-secret

# How long (in seconds) a JWT stays valid.
# Default: 86400 (24 hours)
JWT_EXPIRY_SECS=86400

# ── Initial admin account seeding ─────────────────────────────────────────────
# On first startup (no users in DB), an admin account is created automatically.

# Username for the initial admin. Required.
INITIAL_ADMIN_USERNAME=admin

# Password for the initial admin.
# If omitted, a random password is generated and printed to stdout.
# INITIAL_ADMIN_PASSWORD=change-me-immediately
